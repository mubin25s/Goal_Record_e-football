rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Match screenshots (legacy) ────────────────────────────────────────────
    // Only authenticated users can read match screenshots
    // Only the uploader can write to their own folder, max 5MB images
    match /matches/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Post images (school social feed) ─────────────────────────────────────
    // Anyone can read post images (feed is public)
    // Only authenticated users can upload to their own post-images folder
    // Max 5MB per image, images only
    match /post-images/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── User avatars ──────────────────────────────────────────────────────────
    // Public read for avatars shown in posts/comments
    // Only the user themselves can update their own avatar
    match /avatars/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
